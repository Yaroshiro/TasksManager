@using System.Reflection;
@using System.ComponentModel.DataAnnotations;
@model TasksManager.Models.TaskDTO

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Task</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" disabled="@(!User.IsInRole("Leader"))" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DueToDate" class="control-label"></label>
                <input asp-for="DueToDate" disabled="@(!User.IsInRole("Leader"))" class="form-control" />
                <span asp-validation-for="DueToDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Description" class="control-label"></label>
                <textarea asp-for="Description" disabled="@(!User.IsInRole("Leader"))" class="form-control"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="SelectedUserIds" class="control-label"></label>
                <select asp-for="SelectedUserIds" disabled="@(!User.IsInRole("Leader"))" multiple size="1" class="form-select">
                    @foreach (var user in Model.Users!)
                    {
                        <option value="@user.Id"
                                selected="@(Model.SelectedUserIds.Contains(user.Id) ? "selected" : null)">@user.Name (@user.Email)</option>
                    }
                </select>
                <span asp-validation-for="SelectedUserIds" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary mt-2 mb-2" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
