@model IEnumerable<TasksManager.Models.TaskViewModel>

@{
    ViewData["Title"] = "Tasks";
}

<h1>@ViewData["Title"]</h1>

<form asp-action="Index" class="mb-2" method="get" asp-route-sortOrder="@ViewData["SortOrder"]">
    <div class="d-flex align-items-center gap-2">
        <label class="control-label">Filter: </label>
        <select class="form-select" name="Filter">
            <option value="" selected="@((int?)ViewData["Filter"] == null ? "selected" : null)">All</option>
            @{
                var items = Html.GetEnumSelectList<TaskModel.TaskStatus>();
                foreach (var item in items)
                {
                    <option value=@item.Value selected=@((int?)ViewData["Filter"]! == int.Parse(item.Value) ? "selected" : null)>@item.Text</option>
                }
            }
        </select>
        <input type="submit" class="btn btn-primary" Value="Apply" />
    </div>
</form>

@if (User.IsInRole("Leader"))
{
    <p>
        <a asp-action="Create">Create New</a>
    </p>
}
<table class="table align-middle text-center">
    <thead>
        <tr>
            <th>
                <a asp-action="Index"
                   asp-route-sortOrder="@((string)ViewData["SortOrder"]! == "name" ? "name_desc" : "name")"
                   asp-route-filter="@ViewData["Filter"]">
                    @Html.DisplayNameFor(model => model.Name)
                </a>
            </th>
            <th>
                <a asp-action="Index"
                   asp-route-sortOrder="@((string)ViewData["SortOrder"]! == "status" ? "status_desc" : "status")"
                   asp-route-filter="@ViewData["Filter"]">
                    @Html.DisplayNameFor(model => model.Status)
                </a>
            </th>
            <th>
                <a asp-action="Index"
                   asp-route-sortOrder="@((string)ViewData["SortOrder"]! == "priority" ? "priority_desc" : "priority")"
                   asp-route-filter="@ViewData["Filter"]">
                    @Html.DisplayNameFor(model => model.Priority)
                </a>
            </th>
            <th>
                <a asp-action="Index"
                   asp-route-sortOrder="@((string)ViewData["SortOrder"]! == "duetodate" ? "duetodate_desc" : "duetodate")"
                   asp-route-filter="@ViewData["Filter"]">
                    @Html.DisplayNameFor(model => model.DueToDate)
                </a>
            </th>
            <th>
                <a asp-action="Index"
                   asp-route-sortOrder="@((string)ViewData["SortOrder"]! == "assignmentdate" ? "assignmentdate_desc" : "assignmentdate")"
                   asp-route-filter="@ViewData["Filter"]">
                    @Html.DisplayNameFor(model => model.CreationDate)
                </a>
            </th>
            @if (User.IsInRole("Leader"))
            {
                <th>
                    @Html.DisplayNameFor(model => model.AssignedUserNames)
                </th>
            }
            else
            {
                <th>
                    @Html.DisplayNameFor(model => model.OwnerName)
                </th>
            }
            <th></th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(model => item.Name)
                </td>
                <td>
                    @{
                        string color;
                        switch (item.Status)
                        {
                            case TaskModel.TaskStatus.InProgress:
                                color = "red";
                                break;
                            case TaskModel.TaskStatus.ConfirmationPending:
                                color = "darkorange";
                                break;
                            case TaskModel.TaskStatus.Completed:
                                color = "lightgreen";
                                break;
                            case TaskModel.TaskStatus.Deleted:
                                color = "gray";
                                break;
                            default:
                                color = "white";
                                break;
                        }
                    }
                    <span style="color: @color">@Html.DisplayFor(model => item.Status)</span>
                </td>
                <td class="@TasksController.GetPriorityClass(item.Priority)">
                    @Html.DisplayFor(model => item.Priority)
                </td>
                <td>
                    @if (item.DueToDate == null)
                    {
                        @:ー
                    }
                    else
                    {
                        @Html.DisplayFor(model => item.DueToDate)
                    }
                </td>
                <td>
                    @if (item.CreationDate == null)
                    {
                        @:ー
                    }
                    else
                    {
                        @Html.DisplayFor(model => item.CreationDate)
                    }
                </td>
                @if (User.IsInRole("Leader"))
                {
                    <td>
                        @foreach (var name in item.AssignedUserNames!)
                        {
                            <div>@name</div>
                        }
                    </td>
                }
                else
                {
                    <td>
                        @Html.DisplayFor(_ => item.OwnerName)
                    </td>
                }
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                    @if (User.IsInRole("Leader") && item.Status != TaskModel.TaskStatus.Deleted)
                    {
                        @: |
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>

                        @: |
                        <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    }
                </td>
                <td>
                    @if (User.IsInRole("Member") && item.Status == TaskModel.TaskStatus.InProgress)
                    {
                        <form asp-action="Submit" method="get" asp-route-id="@item.Id">
                            <input type="submit" class="btn btn-success mt-2 mb-2" value="Submit" />
                        </form>
                    }
                    else if (User.IsInRole("Leader") && item.Status == TaskModel.TaskStatus.ConfirmationPending)
                    {
                        <form asp-action="Submit" method="get" asp-route-id="@item.Id">
                            <input type="submit" class="btn btn-success mt-2 mb-2" value="Check" />
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
