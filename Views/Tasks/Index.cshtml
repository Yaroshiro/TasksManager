@model IEnumerable<TasksManager.Models.TaskModel>

@{
    ViewData["Title"] = "Tasks";
}

<h1>@ViewData["Title"]</h1>

<form asp-action="Index" class="mb-2" method="get">
    <div class="d-flex align-items-center gap-2">
        <label class="control-label">Filter: </label>
        <select class="form-select" name="SelectedStatus">
            <option value=-1 selected="@((int?)ViewData["CurrentFilter"] == null || (int?)ViewData["CurrentFilter"]! == -1 ? "selected" : null)">All</option>
            @{
                var items = Html.GetEnumSelectList<TaskModel.TaskStatus>();
                foreach (var item in items)
                {
                    <option value=@item.Value selected=@((int?)ViewData["CurrentFilter"]! == int.Parse(item.Value) ? "selected" : null)>@item.Text</option>
                }
            }
        </select>
        <input type="submit" class="btn btn-primary" Value="Apply" />
    </div>
</form>

@if (User.IsInRole("Leader"))
{
    <p>
        <a asp-action="Create">Create New</a>
    </p>
}
<table class="table align-middle text-center">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th style="width: 10%">
                @Html.DisplayNameFor(model => model.DueToDate)
            </th>
            <th style="width: 30%">
                @Html.DisplayNameFor(model => model.Description)
            </th>
            @if (User.IsInRole("Leader"))
            {
                <th>
                    @Html.DisplayNameFor(model => model.AssignedUsers)
                </th>
            }
            else
            {
                <th>
                    @Html.DisplayNameFor(model => model.Owner)
                </th>
            }
            <th></th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(model => item.Name)
                </td>
                <td>
                    @{
                        string color;
                        switch (item.Status)
                        {
                            case TaskModel.TaskStatus.InProgress:
                                color = "red";
                                break;
                            case TaskModel.TaskStatus.ConfirmationPending:
                                color = "darkorange";
                                break;
                            case TaskModel.TaskStatus.Completed:
                                color = "lightgreen";
                                break;
                            case TaskModel.TaskStatus.Deleted:
                                color = "gray";
                                break;
                            default:
                                color = "white";
                                break;
                        }
                    }
                    <span style="color: @color">@Html.DisplayFor(model => item.Status)</span>
                </td>
                <td>
                    @if (item.DueToDate == null)
                    {
                        @:ー
                    }
                    else
                    {
                        @Html.DisplayFor(model => item.DueToDate);
                    }
                </td>
                <td>
                    @if (item.Description.Length < 108)
                    {
                        @Html.DisplayFor(model => item.Description)
                    }
                    else
                    {
                        @(item.Description.Substring(0, 107) + "...")
                    }
                </td>
                @if (User.IsInRole("Leader"))
                {
                    <td>
                        @foreach (var user in item.AssignedUsers!)
                        {
                            <div>@user.Name</div>
                        }
                    </td>
                }
                else
                {
                    <td>
                        @Html.DisplayFor(_ => item.Owner!.Name)
                    </td>
                }
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                    @if (User.IsInRole("Leader") && item.Status != TaskModel.TaskStatus.Deleted)
                    {
                        @: |
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>

                        @: |
                        <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    }
                </td>
                <td>
                    @if (User.IsInRole("Member") && item.Status == TaskModel.TaskStatus.InProgress)
                    {
                        <form asp-action="Submit" asp-route-id="@item.Id">
                            <button type="submit" class="btn btn-success mt-2 mb-2">Submit</button>
                        </form>
                    }
                    else if (User.IsInRole("Leader") && item.Status == TaskModel.TaskStatus.ConfirmationPending)
                    {
                        <form asp-action="Approve" asp-route-id="@item.Id">
                            <input name="action" type="submit" class="btn btn-success mt-2 mb-2" value="Approve" />
                            <input name="action" type="submit" class="btn btn-secondary mt-2 mb-2" value="Reject" />
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
